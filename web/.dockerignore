# Keep the build context small and secret-free. Only package*.json is COPY'd;
# everything else returns via the compose bind mount at runtime.

# Dependencies & build output (never bake the macOS-arm64 native binary)
node_modules
.next
out
dist
build
.cache

# Local data dir (Postgres data lives in the `pgdata` named volume, not here)
data

# VCS & meta
.git
.gitignore

# Secrets — does NOT affect compose env_file, which reads .env.local directly
.env
.env.*

# Logs / coverage / editor / OS
*.log
coverage
.DS_Store
.idea
.vscode
*.swp

# Docker scaffolding itself
Dockerfile.dev
docker-compose.dev.yml
.dockerignore
